{
  "name": "@ruminaider/newrelic-mcp-server",
  "description": "A comprehensive MCP server for NewRelic — 25 tools for NRQL, entities, alerts, dashboards, logs, and more",
  "version": "2.1.0",
  "type": "module",
  "module": "index.ts",
  "bin": {
    "newrelic-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "clean": "rm -rf dist",
    "lint": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "watch": "nodemon --watch src --ext ts --exec \"npm run build\"",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "newrelic",
    "new-relic",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "observability",
    "monitoring",
    "apm",
    "nerdgraph",
    "ai-tools",
    "llm-tools",
    "claude"
  ],
  "author": "Albert Gwo",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.14",
    "nodemon": "^3.1.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "graphql": "^16.11.0",
    "graphql-request": "^7.1.2",
    "zod": "^3.24.4"
  }
}
